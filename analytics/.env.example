# Variables de entorno (Railway → Variables). NO commitear el .env real.

# Postgres (misma base de Railway)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PUERTO/railway
# PGSSL=true

# Zona horaria para agrupar por día/hora (por defecto America/Santo_Domingo)
TZ_DISPLAY=America/Santo_Domingo

# Cotizaciones — viven en una base MSSQL aparte (site4now). Conexión propia.
# ⚠️ Los valores reales van en las Variables de Railway, NO en el repo.
MSSQL_SERVER=sql5045.site4now.net
MSSQL_DATABASE=DB_A61822_simJH
MSSQL_USER=<usuario>
MSSQL_PASSWORD=<clave>
MSSQL_PORT=1433
MSSQL_ENCRYPT=false
# tabla/columnas (por defecto: iCotizacionesWebIA / FechaRegistro / total)
# MSSQL_QUOTES_TABLE=iCotizacionesWebIA
# MSSQL_QUOTES_DATE=FechaRegistro
# MSSQL_QUOTES_AMOUNT=total

# Coste por mensaje (la base no lo guarda: se aplica esta tarifa).
MSG_COST_OUT=0.03          # coste por mensaje saliente
MSG_COST_IN=0              # coste por mensaje entrante
MSG_COST_CURRENCY=USD

# PORT=8080
