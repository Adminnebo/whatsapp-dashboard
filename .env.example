# Variables de entorno del servicio (Railway → Variables). NO commitear el .env real.

# Postgres (misma base de Railway que usa el dashboard actual)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PUERTO/railway
# PGSSL=true   # solo si tu Postgres exige SSL

# GoHighLevel (Private Integration Token de la subcuenta + Location ID)
GHL_PIT=pit-xxxxxxxx
LOCATION_ID=bzRd2deoIdOClJZ44bv5
# BOT_STATUS_FIELD_ID=M2ONiagYfBbAJrC9jhgO   # id del custom field "Bot Status"
# HANDOFF_TAG=handoff

# WhatsApp Cloud API (para enviar; recibir sigue en tu flujo de Meta)
WHATSAPP_TOKEN=EAAG...
WHATSAPP_PHONE_ID=302766349596365

# URL pública del servicio (para que WhatsApp pueda leer /api/media al enviar adjuntos)
PUBLIC_URL=https://tu-dashboard.up.railway.app

# Opcionales
# PORT=8080
# JSON_LIMIT=60mb
